# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/body_timeline

# JWT
JWT_SECRET_KEY=change-me-to-a-random-secret-key
JWT_ACCESS_TOKEN_EXPIRES=900
JWT_REFRESH_TOKEN_EXPIRES=2592000

# App
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=change-me-to-another-random-secret-key

# Storage (local | s3)
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=uploads
# S3-compatible settings (for production)
# STORAGE_BACKEND=s3
# S3_BUCKET=body-timeline-uploads
# S3_REGION=us-east-1
# S3_ACCESS_KEY=your-access-key
# S3_SECRET_KEY=your-secret-key
# S3_ENDPOINT_URL=https://your-r2-endpoint.r2.cloudflarestorage.com

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
