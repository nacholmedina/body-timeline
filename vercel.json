{
  "installCommand": "cd web && npm install",
  "buildCommand": "cd web && npm run build",
  "framework": "sveltekit",
  "rewrites": [
    {
      "source": "/api/v1/:path*",
      "destination": "/api/index.py"
    },
    {
      "source": "/api/health",
      "destination": "/api/index.py"
    }
  ]
}
